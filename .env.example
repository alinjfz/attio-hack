# ── Attio ──────────────────────────────────────────
ATTIO_API_TOKEN=           # from build.attio.com (also auto in server fns)

# ── Superlinked SIE (required for fit scoring) ─────
SUPERLINKED_API_KEY=       # Discord / hackathon
SUPERLINKED_CLUSTER_URL=   # hackathon cluster endpoint
SUPERLINKED_MODEL=BAAI/bge-m3

# ── Gemini (required for drafts) ───────────────────
# Google AI Studio: AIza (standard) or AQ. (auth key) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tavily (OPTIONAL — web enrichment, uses credits) ─
# Leave disabled to run on Gemini + Superlinked only.
# Set ENABLE_TAVILY=true only when you want web/LinkedIn bullets with sources.
TAVILY_API_KEY=
ENABLE_TAVILY=false

# ── SLNG (OPTIONAL — audio list summary) ───────────
SLNG_API_KEY=
ENABLE_SLNG=false
# Deployed TTS model + voice (use aura:2-en, not aura:2)
SLNG_TTS_MODEL=slng/deepgram/aura:2-en
SLNG_TTS_VOICE=aura-2-thalia-en

# ── Webhook API + SLNG audio hosting ─────────────────
WEBHOOK_SECRET=
PORT=3001

# Run:  pnpm api:public
# Copy the printed trycloudflare.com URL into Attio app settings → api_public_url.
# Update Attio every time you restart the tunnel (URL changes). Keep the terminal open.
API_PUBLIC_URL=

# ── n8n local instance (Docker — pnpm n8n:dev) ─────
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
