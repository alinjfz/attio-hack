# ── Attio ──────────────────────────────────────────
ATTIO_API_TOKEN=           # from build.attio.com (also auto in server fns)

# ── Superlinked SIE (required for fit scoring) ─────
SUPERLINKED_API_KEY=       # Discord / hackathon
SUPERLINKED_CLUSTER_URL=   # hackathon cluster endpoint
SUPERLINKED_MODEL=BAAI/bge-m3

# ── Gemini (required for drafts) ───────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tavily (OPTIONAL — web enrichment, uses credits) ─
# Leave disabled to run on Gemini + Superlinked only.
# Set ENABLE_TAVILY=true only when you want web/LinkedIn bullets with sources.
TAVILY_API_KEY=
ENABLE_TAVILY=false

# ── SLNG (OPTIONAL — audio list summary) ───────────
SLNG_API_KEY=
ENABLE_SLNG=false

# ── n8n + webhook API (OPTIONAL — side demo path) ──
WEBHOOK_SECRET=            # random string for api/ auth
PORT=3001
# Public URL for the webhook API.
# - Host-native dev + pnpm n8n:smoke:  http://localhost:3001
# - n8n in Docker calling API on host:  http://host.docker.internal:3001
# - Public demo (ngrok):                https://xxxx.ngrok-free.app
API_PUBLIC_URL=http://localhost:3001

# ── n8n local instance (Docker — pnpm n8n:dev) ─────
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
