# ── Attio ──────────────────────────────────────────
ATTIO_API_TOKEN=           # from build.attio.com (also auto in server fns)

# ── Superlinked SIE ────────────────────────────────
SUPERLINKED_API_KEY=       # Discord / hackathon
SUPERLINKED_CLUSTER_URL=   # hackathon cluster endpoint
SUPERLINKED_MODEL=BAAI/bge-m3

# ── Gemini ─────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Tavily (Phase 3) ───────────────────────────────
TAVILY_API_KEY=
ENABLE_TAVILY=false

# ── SLNG (Phase 3) ─────────────────────────────────
SLNG_API_KEY=
ENABLE_SLNG=false

# ── n8n webhook API (Phase 3) ──────────────────────
WEBHOOK_SECRET=            # random string for api/ auth
PORT=3001
API_PUBLIC_URL=            # ngrok or deploy URL for n8n
